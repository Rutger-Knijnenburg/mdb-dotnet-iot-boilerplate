# =============================================================================
# Shared environment configuration for IoT and Vector Search use cases
# Copy this file to .env and fill in your values
# =============================================================================

# MongoDB connection (required for both use cases)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=spring_vector_demo

# Atlas Embedding API - Voyage AI models (required for Vector Search use case)
# Create a Model API key in MongoDB Atlas UI: Project Settings > Model API Keys
ATLAS_API_KEY=your_atlas_model_api_key

# Vector Search configuration (Vector Search use case)
VECTOR_COLLECTION=vector_store
VECTOR_INDEX=vector_index
VECTOR_EMBEDDING_MODEL=voyage-4-large
